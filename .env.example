APP_ENV=development
APP_PORT=8081

BACKEND_BASE_URL=http://localhost:8080
REQUEST_TIMEOUT=15s

FALLBACK_COUNTRY_CODE=PK
GEOIP_DB_PATH=./geoip/GeoLite2-Country.mmdb
GEOIP_CACHE_ENABLED=true
GEOIP_CACHE_TTL=5m
GEOIP_CACHE_MAX_KEYS=100000

REDIS_ADDR=localhost:6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_POOL_SIZE=256

# Cache backend selection:
# - CACHE_PROVIDER=keydb (recommended) uses KEYDB_* vars (falls back to REDIS_* if missing)
# - CACHE_PROVIDER=redis uses REDIS_* vars
# - CACHE_URL overrides both (e.g. redis://:pass@host:6379/0)
CACHE_PROVIDER=keydb
CACHE_URL=
KEYDB_ADDR=localhost:6379
KEYDB_PASSWORD=
KEYDB_DB=0
KEYDB_POOL_SIZE=256

CACHE_TTL=5m
CACHE_STALE_WINDOW=1m
NEGATIVE_CACHE_TTL=30s

MEM_CACHE_ENABLED=true
MEM_CACHE_TTL=30s
MEM_CACHE_STALE_WINDOW=30s
MEM_CACHE_NEGATIVE_TTL=5s
MEM_CACHE_MAX_KEYS=200000

# L1 eviction tuning under high concurrency (optional)
MEM_CACHE_EVICT_SCAN=2048
MEM_CACHE_HARD_MAX_MULTIPLIER=2

BACKEND_MAX_INFLIGHT=200

RUST_LOG=info

# Performance logging/metrics controls (safe for high RPS)
LOG_SLOW_MS=50
LOG_SAMPLE_RATE=1000
LOG_TABLE_ENABLED=false
METRICS_SAMPLE_RATE=1000
