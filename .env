APP_ENV=development
APP_PORT=8081

BACKEND_BASE_URL=http://localhost:8080
REQUEST_TIMEOUT=15s

FALLBACK_COUNTRY_CODE=PK
GEOIP_DB_PATH=./geoip/GeoLite2-Country.mmdb
GEOIP_CACHE_ENABLED=true
GEOIP_CACHE_TTL=5m
GEOIP_CACHE_MAX_KEYS=100000

REDIS_ADDR=localhost:6379
REDIS_PASSWORD=
REDIS_DB=0

CACHE_TTL=5m
CACHE_STALE_WINDOW=1m
NEGATIVE_CACHE_TTL=30s

MEM_CACHE_ENABLED=true
MEM_CACHE_TTL=30s
MEM_CACHE_STALE_WINDOW=30s
MEM_CACHE_NEGATIVE_TTL=5s
MEM_CACHE_MAX_KEYS=200000

BACKEND_MAX_INFLIGHT=200

RUST_LOG=info

# Performance logging/metrics controls (safe for high RPS)
LOG_SLOW_MS=50
LOG_SAMPLE_RATE=1000
LOG_TABLE_ENABLED=false
METRICS_SAMPLE_RATE=1000
